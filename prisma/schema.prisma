generator client {
    provider = "prisma-client-js"
}

datasource db {
    provider = "mysql"
    url      = env("DATABASE_URL")
}

model Person {
    id               String            @id @default(cuid())
    name             String
    phone            String?
    email            String?
    address          String?           @db.Text
    notes            String?           @db.Text
    createdAt        DateTime          @default(now())
    updatedAt        DateTime          @updatedAt
    cashTransactions CashTransaction[]
    goldTransactions GoldTransaction[]

    @@map("persons")
}

model CashLedger {
    id        String   @id @default(cuid())
    balance   Float    @default(0)
    updatedAt DateTime @updatedAt

    @@map("cash_ledger")
}

model CashTransaction {
    id         String   @id @default(cuid())
    personId   String
    person     Person   @relation(fields: [personId], references: [id])
    type       String // Dynamic: references transaction_types.value
    amount     Float
    date       DateTime @default(now())
    notes      String?  @db.Text
    billNumber String?  @unique @default(cuid())
    createdAt  DateTime @default(now())
    updatedAt  DateTime @updatedAt

    @@index([personId])
    @@index([type])
    @@index([date])
    @@map("cash_transactions")
}

model GoldInventory {
    id        String   @id @default(cuid())
    carat     String // Dynamic: references carat_options.value
    weight    Float    @default(0)
    updatedAt DateTime @updatedAt

    @@unique([carat])
    @@map("gold_inventory")
}

model GoldTransaction {
    id          String   @id @default(cuid())
    personId    String
    person      Person   @relation(fields: [personId], references: [id])
    type        String // Dynamic: references transaction_types.value
    carat       String // Dynamic: references carat_options.value
    weight      Float
    ratePerGram Float?
    totalValue  Float?
    date        DateTime @default(now())
    notes       String?  @db.Text
    billNumber  String?  @unique @default(cuid())
    createdAt   DateTime @default(now())
    updatedAt   DateTime @updatedAt

    @@index([personId])
    @@index([type])
    @@index([carat])
    @@index([date])
    @@map("gold_transactions")
}

// ─── Dynamic Module Config ───────────────────────────────────────

model CaratOption {
    id        String   @id @default(cuid())
    value     String   @unique // e.g. "22k"
    label     String // e.g. "22 Karat"
    sortOrder Int      @default(0)
    isActive  Boolean  @default(true)
    createdAt DateTime @default(now())
    updatedAt DateTime @updatedAt

    @@map("carat_options")
}

model TransactionTypeOption {
    id        String   @id @default(cuid())
    value     String   @unique // e.g. "LENT"
    label     String // e.g. "Lent Out"
    color     String   @default("#6b7280") // badge color
    sortOrder Int      @default(0)
    isActive  Boolean  @default(true)
    createdAt DateTime @default(now())
    updatedAt DateTime @updatedAt

    @@map("transaction_types")
}

model AppSetting {
    id        String   @id @default(cuid())
    key       String   @unique // e.g. "company_name", "company_phone"
    value     String   @db.Text
    updatedAt DateTime @updatedAt

    @@map("app_settings")
}
